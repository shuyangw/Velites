# ============================================================================
# VELITES - Quantamental Research Agent Configuration
# ============================================================================
# Copy this file to .env and fill in your API keys

# Application
ENVIRONMENT="development"
DEBUG=true

# ============================================================================
# SCOUT - Data Ingestion
# ============================================================================

# ArXiv settings (defaults are fine for most cases)
# ARXIV_CATEGORIES=["cs.AI", "cs.LG", "cs.AR", "cs.CV"]
# ARXIV_MAX_RESULTS=100
# ARXIV_LOOKBACK_HOURS=24

# News API - Tiingo (https://api.tiingo.com/)
TIINGO_API_KEY="<YOUR_TIINGO_API_KEY>"

# Market Data Provider: "yfinance" (dev) or "alpaca" (prod)
MARKET_DATA_PROVIDER="yfinance"

# Alpaca API (https://alpaca.markets/)
ALPACA_API_KEY="<YOUR_ALPACA_API_KEY>"
ALPACA_SECRET_KEY="<YOUR_ALPACA_SECRET_KEY>"
ALPACA_BASE_URL="https://paper-api.alpaca.markets"

# ============================================================================
# ANALYST - LLM and Sentiment
# ============================================================================

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY="<YOUR_ANTHROPIC_API_KEY>"
# OPENAI_API_KEY="<YOUR_OPENAI_API_KEY>"

# LLM Model settings
LLM_MODEL="claude-sonnet-4-5-20250929"
LLM_TEMPERATURE=0.1

# ============================================================================
# COURIER - Signal Dispatch
# ============================================================================

# Homeguard integration (optional)
# HOMEGUARD_WEBHOOK_URL=""
HOMEGUARD_OUTPUT_DIR="output/signals"

# Liquidity guards
MAX_SPREAD_PCT=2.0
MIN_VOLUME_USD=500000.0

# ============================================================================
# SCRIBE - Database
# ============================================================================

DATABASE_URL="sqlite:///data/velites.db"
