# Velites Environment Configuration
# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=development
DEBUG=false

# Data paths
DATA_DIR=data
KNOWLEDGE_GRAPH_PATH=data/knowledge_graph_v1_2.json

# Scout - News APIs
TIINGO_API_KEY=your_tiingo_api_key
NEWSDATA_API_KEY=your_newsdata_api_key

# Scout - Market Data
MARKET_DATA_PROVIDER=yfinance  # yfinance or alpaca
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Analyst - LLM
LLM_PROVIDER=openai  # openai or anthropic
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# Courier - Homeguard
HOMEGUARD_WEBHOOK_URL=
HOMEGUARD_OUTPUT_DIR=output/signals

# Courier - Liquidity Guards
MAX_SPREAD_PCT=2.0
MIN_VOLUME_USD=500000

# Scribe - Database
DATABASE_URL=sqlite:///data/velites.db

# Scheduling
RUN_INTERVAL_HOURS=4
